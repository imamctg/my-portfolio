{
  "compilerOptions": {
    "types": ["node", "next", "next-intl"],

    "jsx": "preserve",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./client/*"]
    },
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],

    "allowJs": true,
    "skipLibCheck": true,
    "strict": false,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "incremental": true,
    "module": "esnext",
    "esModuleInterop": true,
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": [
    "next-env.d.ts",
    ".next/types/**/*.ts",
    "**/*.ts",
    "**/*.tsx",
    "next-intl.config.ts"
  ],
  "exclude": ["node_modules"]
}
